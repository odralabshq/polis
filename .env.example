# Copy to .env and fill in values.
# All POLIS_*_VERSION vars are set to the same release tag — services are versioned in lockstep.
# Defaults to "latest" (locally built images from `just build`).
# Set to a release tag (e.g. v0.4.0) to use specific GHCR images.
POLIS_RESOLVER_VERSION=latest
POLIS_CERTGEN_VERSION=latest
POLIS_GATE_VERSION=latest
POLIS_SENTINEL_VERSION=latest
POLIS_SCANNER_VERSION=latest
POLIS_WORKSPACE_VERSION=latest
POLIS_HOST_INIT_VERSION=latest
POLIS_STATE_VERSION=latest
POLIS_TOOLBOX_VERSION=latest
